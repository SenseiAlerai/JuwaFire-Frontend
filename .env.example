# ── Database (PostgreSQL on your VPS) ──────────────────────────
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL="postgres://juwafire:CHANGEME@YOUR_VPS_IP:5432/juwafire"
# Set to "true" only if your Postgres requires SSL
DATABASE_SSL="false"

# ── Auth.js ────────────────────────────────────────────────────
# Generate with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="CHANGEME_long_random_string"
# Your site URL (use http://localhost:3000 in dev)
AUTH_URL="http://localhost:3000"

# ── Google OAuth ───────────────────────────────────────────────
# From https://console.cloud.google.com → Credentials → OAuth client (Web)
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID="CHANGEME.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="CHANGEME"
